{% doc %}
  @prompt
    I need one timer Section. section title have Timer . the date should taken by customize setting. format is HH/MM/SS., i need 12 hour format, I need that End time should be taken as Date, Then show how many hours , minms and sec to go for this date should display
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-countdown-timer__title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_spacing }}px;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
  }

  .ai-countdown-timer__display-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.unit_spacing }}px;
    flex-wrap: wrap;
  }

  .ai-countdown-timer__unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ block.settings.unit_width }}px;
  }

  .ai-countdown-timer__value-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    color: {{ block.settings.number_color }};
    line-height: 1;
    margin-bottom: {{ block.settings.label_spacing }}px;
  }

  .ai-countdown-timer__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    text-transform: {{ block.settings.label_transform }};
  }

  .ai-countdown-timer__separator-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    color: {{ block.settings.number_color }};
    line-height: 1;
    margin-bottom: {{ block.settings.label_spacing }}px;
  }

  .ai-countdown-timer__expired-{{ ai_gen_id }} {
    font-size: {{ block.settings.expired_size }}px;
    color: {{ block.settings.expired_color }};
    padding: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-countdown-timer__unit-{{ ai_gen_id }} {
      min-width: {{ block.settings.unit_width | times: 0.8 }}px;
    }

    .ai-countdown-timer__value-{{ ai_gen_id }} {
      font-size: {{ block.settings.number_size | times: 0.8 }}px;
    }

    .ai-countdown-timer__separator-{{ ai_gen_id }} {
      font-size: {{ block.settings.number_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.title != blank %}
    <h2 class="ai-countdown-timer__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  {% endif %}

  <div class="ai-countdown-timer__display-{{ ai_gen_id }}" data-timer-display>
    <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
      <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-hours>00</div>
      <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</div>
    </div>

    {% if block.settings.show_separator %}
      <div class="ai-countdown-timer__separator-{{ ai_gen_id }}">:</div>
    {% endif %}

    <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
      <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-minutes>00</div>
      <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.minutes_label }}</div>
    </div>

    {% if block.settings.show_separator %}
      <div class="ai-countdown-timer__separator-{{ ai_gen_id }}">:</div>
    {% endif %}

    <div class="ai-countdown-timer__unit-{{ ai_gen_id }}">
      <div class="ai-countdown-timer__value-{{ ai_gen_id }}" data-seconds>00</div>
      <div class="ai-countdown-timer__label-{{ ai_gen_id }}">{{ block.settings.seconds_label }}</div>
    </div>
  </div>

  <div class="ai-countdown-timer__expired-{{ ai_gen_id }}" data-expired-message style="display: none;">
    {{ block.settings.expired_message }}
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.timerDisplay = this.querySelector('[data-timer-display]');
        this.hoursElement = this.querySelector('[data-hours]');
        this.minutesElement = this.querySelector('[data-minutes]');
        this.secondsElement = this.querySelector('[data-seconds]');
        this.expiredMessage = this.querySelector('[data-expired-message]');
        this.interval = null;
      }

      connectedCallback() {
        if (this.endDate) {
          this.startTimer();
        }
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      parseEndDateTime() {
        if (!this.endDate) {
          return null;
        }

        const dateParts = this.endDate.split('-');
        if (dateParts.length !== 3) {
          return null;
        }

        const year = parseInt(dateParts[0], 10);
        const month = parseInt(dateParts[1], 10) - 1;
        const day = parseInt(dateParts[2], 10);

        if (isNaN(year) || isNaN(month) || isNaN(day)) {
          return null;
        }

        let hours = 0;
        let minutes = 0;
        let seconds = 0;

        if (this.endTime) {
          const timeParts = this.endTime.split(':');
          if (timeParts.length === 3) {
            hours = parseInt(timeParts[0], 10) || 0;
            minutes = parseInt(timeParts[1], 10) || 0;
            seconds = parseInt(timeParts[2], 10) || 0;
          }
        }

        const endDate = new Date(year, month, day, hours, minutes, seconds);

        if (isNaN(endDate.getTime())) {
          return null;
        }

        return endDate;
      }

      startTimer() {
        const endDate = this.parseEndDateTime();

        if (!endDate) {
          return;
        }

        this.updateTimer(endDate);

        this.interval = setInterval(() => {
          this.updateTimer(endDate);
        }, 1000);
      }

      updateTimer(endDate) {
        const now = new Date();
        const distance = endDate - now;

        if (distance < 0) {
          this.showExpiredMessage();
          return;
        }

        const hours = Math.floor(distance / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        this.hoursElement.textContent = String(hours).padStart(2, '0');
        this.minutesElement.textContent = String(minutes).padStart(2, '0');
        this.secondsElement.textContent = String(seconds).padStart(2, '0');
      }

      showExpiredMessage() {
        if (this.interval) {
          clearInterval(this.interval);
        }
        this.timerDisplay.style.display = 'none';
        this.expiredMessage.style.display = 'block';
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Timer",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Timer settings"
    },
    {
      "type": "text",
