      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "unit_width",
      "label": "Unit width",
      "min": 60,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Title spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
